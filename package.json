{
  "name": "chairmatch",
  "version": "6.0.0",
  "description": "ChairMatch — Dein Beauty-Partner in ganz Deutschland",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "ios:build": "cd mobile && npx eas-cli build --platform ios --profile production --non-interactive",
    "ios:submit": "cd mobile && npx eas-cli submit --platform ios --profile production --non-interactive --latest"
  },
  "author": "Yusuf Demir",
  "license": "MIT",
  "keywords": [
    "beauty",
    "salon",
    "booking",
    "germany",
    "appointment"
  ],
  "dependencies": {
    "@next/third-parties": "^16.2.6",
    "@sentry/nextjs": "^9.0.0",
    "@stripe/stripe-js": "^8.10.0",
    "@supabase/supabase-js": "^2.98.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "web-push": "^3.6.7",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^10.0.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
