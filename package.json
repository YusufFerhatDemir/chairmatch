{
  "name": "chairmatch",
  "version": "6.0.0",
  "description": "ChairMatch — Dein Beauty-Partner in ganz Deutschland",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "cap:init": "npx cap add ios && npx cap add android && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "cap:assets": "npx capacitor-assets generate --iconBackgroundColor '#080706' --iconBackgroundColorDark '#080706' --splashBackgroundColor '#080706' --splashBackgroundColorDark '#080706'",
    "ios:archive": "npx cap sync ios && npx cap open ios",
    "android:bundle": "npx cap sync android && cd android && ./gradlew bundleRelease"
  },
  "author": "Yusuf Demir",
  "license": "MIT",
  "keywords": [
    "beauty",
    "salon",
    "booking",
    "germany",
    "appointment"
  ],
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@stripe/stripe-js": "^8.10.0",
    "@supabase/supabase-js": "^2.98.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^10.0.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.0",
    "@vitejs/plugin-react": "^4.5.2"
  }
}
