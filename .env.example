# ============================================================
# ChairMatch — Umgebungsvariablen (Vorlage)
# ============================================================
# Kopiere diese Datei als ".env.local" für lokale Entwicklung.
# Für Production: alle Werte in Vercel → Settings → Environment Variables eintragen.
# WICHTIG: .env.local niemals committen!
# ============================================================


# ── SUPABASE ─────────────────────────────────────────────────
# Supabase Dashboard → Project → Settings → API

# Deine Projekt-URL (sieht aus wie: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT-ID.supabase.co

# Anon Key — für Browser/Client-Side, öffentlich sichtbar
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...DEIN_ANON_KEY...

# Service-Role Key — NUR server-seitig, NIEMALS im Browser!
# Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...DEIN_SERVICE_ROLE_KEY...


# ── STRIPE ───────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys

# Publishable Key — öffentlich (beginnt mit pk_live_ oder pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_DEIN_PUBLISHABLE_KEY

# Secret Key — NUR server-seitig (beginnt mit sk_live_ oder sk_test_)
STRIPE_SECRET_KEY=sk_test_DEIN_SECRET_KEY

# Webhook Secret — Stripe Dashboard → Webhooks → Signing Secret
# Lokal: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` → gibt whsec_ aus
STRIPE_WEBHOOK_SECRET=whsec_DEIN_WEBHOOK_SECRET

# Abo-Preis-IDs — Stripe Dashboard → Products → jeweiliger Preis → Price ID
# Format: price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_STARTER_PREIS_ID
STRIPE_PRICE_PREMIUM=price_PREMIUM_PREIS_ID
STRIPE_PRICE_GOLD=price_GOLD_PREIS_ID


# ── E-MAIL (Resend) ──────────────────────────────────────────
# resend.com → Dashboard → API Keys → Create API Key
RESEND_API_KEY=re_DEIN_RESEND_API_KEY

# Absender-Adresse für transaktionale E-Mails
# Muss eine verifizierte Domain in Resend sein (z. B. chairmatch.de)
# Format: "Name <adresse@domain.de>"
RESEND_FROM_EMAIL=ChairMatch <noreply@chairmatch.de>


# ── WEB PUSH NOTIFICATIONS (VAPID) ──────────────────────────
# Einmalig generieren mit: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=DEIN_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=DEIN_VAPID_PRIVATE_KEY
# Deine eigene E-Mail-Adresse (für VAPID-Identifikation)
VAPID_EMAIL=mailto:admin@chairmatch.de


# ── APP URL ──────────────────────────────────────────────────
# Lokal: http://localhost:3000
# Production: https://chairmatch.de (oder deine Vercel-URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── ADMIN & CRON SECRETS ─────────────────────────────────────
# Einmalig für Admin-Promotion-Setup — beliebiger sicherer String (z. B. per `openssl rand -hex 32`)
ADMIN_SETUP_KEY=ein-langer-zufaelliger-geheimstring

# Authentifizierung für automatische Cron-Jobs (z. B. Hard-Delete-Task)
CRON_SECRET=ein-anderer-langer-zufaelliger-geheimstring
