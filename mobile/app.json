{
  "expo": {
    "name": "ChairMatch",
    "slug": "chairmatch",
    "owner": "yusufferhatdemirs-team",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chairmatch",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0F",
    "primaryColor": "#B09060",
    "ios": {
      "bundleIdentifier": "de.chairmatch.app",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "de",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "de.chairmatch.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0B0F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#B09060"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "18d077a8-c1f5-4c1a-bdd0-6e9e416a4ac4"
      }
    }
  }
}
